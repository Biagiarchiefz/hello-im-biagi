{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "biagiarchiefz.vercel.app" }],
      "destination": "https://biagi.kodingin.id/$1",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/((?!assets/|.*\\..*).*)", "destination": "/index.html" }]
}
